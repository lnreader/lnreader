{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["nitrotts"],
  "ios": {
    "iosModuleName": "NitroTts"
  },
  "android": {
    "androidNamespace": ["nitrotts"],
    "androidCxxLibName": "NitroTts"
  },
  "autolinking": {
    "TtsFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridTtsFactory"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridTtsFactory"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
